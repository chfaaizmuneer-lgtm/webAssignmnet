<%- include('header') %>

<div class="signup-wrapper">

  <!-- Left panel — branding -->
  <aside class="signup-aside d-none d-lg-flex">
    <div class="aside-inner">
      <a href="/" class="brand-logo">
        <span class="logo-mark">M</span>
        <span class="logo-text">MyApp</span>
      </a>

      <div class="aside-body">
        <h2 class="aside-headline">Start building<br />your future today.</h2>
        <p class="aside-sub">Join 40,000+ teams who ship faster with MyApp.</p>

        <ul class="feature-list mt-5">
          <li>
            <span class="feature-icon"><i class="bi bi-lightning-charge-fill"></i></span>
            <div>
              <strong>Blazing fast</strong>
              <p>Zero config. Up and running in seconds.</p>
            </div>
          </li>
          <li>
            <span class="feature-icon"><i class="bi bi-shield-check-fill"></i></span>
            <div>
              <strong>Enterprise-grade security</strong>
              <p>SOC 2 Type II certified. Your data stays yours.</p>
            </div>
          </li>
          <li>
            <span class="feature-icon"><i class="bi bi-people-fill"></i></span>
            <div>
              <strong>Built for teams</strong>
              <p>Real-time collaboration without the chaos.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="aside-testimonial">
        <p>"MyApp cut our deploy time in half. We'll never go back."</p>
        <div class="testimonial-author">
          <div class="avatar-placeholder">JK</div>
          <div>
            <strong>Jamie Kim</strong>
            <span>Lead Engineer, Vercel</span>
          </div>
        </div>
      </div>
    </div>
  </aside>

  <!-- Right panel — form -->
  <main class="signup-main">
    <div class="signup-form-wrap">

      <!-- Mobile logo -->
      <a href="/" class="brand-logo mobile-brand d-flex d-lg-none mb-5">
        <span class="logo-mark">M</span>
        <span class="logo-text">MyApp</span>
      </a>

      <div class="form-header mb-4">
        <h1 class="form-title">Create your account</h1>
        <p class="form-sub">Already have one? <a href="#">Sign in</a></p>
      </div>

      <!-- Server-side error alert -->
      <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <strong>Please fix the following:</strong>
          <ul class="mb-0 mt-1 ps-3">
            <% errors.forEach(function(err) { %>
              <li><%= err %></li>
            <% }); %>
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <form action="/signup" method="POST" novalidate id="signupForm">

        <!-- Full Name -->
        <div class="mb-4">
          <label for="fullName" class="form-label">Full name</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person"></i></span>
            <input
              type="text"
              class="form-control"
              id="fullName"
              name="fullName"
              placeholder="Ada Lovelace"
              value="<%= formData.fullName || '' %>"
              required
              minlength="2"
            />
            <div class="invalid-feedback">Please enter your full name (min. 2 characters).</div>
          </div>
        </div>

        <!-- Email -->
        <div class="mb-4">
          <label for="email" class="form-label">Email address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="ada@example.com"
              value="<%= formData.email || '' %>"
              required
            />
            <div class="invalid-feedback">Please enter a valid email address.</div>
          </div>
        </div>

        <!-- Username -->
        <div class="mb-4">
          <label for="username" class="form-label">Username</label>
          <div class="input-group">
            <span class="input-group-text">@</span>
            <input
              type="text"
              class="form-control"
              id="username"
              name="username"
              placeholder="ada_lovelace"
              value="<%= formData.username || '' %>"
              required
              minlength="3"
              pattern="[a-zA-Z0-9_]+"
            />
            <div class="invalid-feedback">Username must be 3+ characters (letters, numbers, underscores).</div>
          </div>
        </div>

        <!-- Password -->
        <div class="mb-2">
          <label for="password" class="form-label">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Min. 8 characters"
              required
              minlength="8"
            />
            <button class="btn btn-outline-secondary toggle-pw" type="button" data-target="password" tabindex="-1">
              <i class="bi bi-eye"></i>
            </button>
            <div class="invalid-feedback">Password must be at least 8 characters.</div>
          </div>
        </div>

        <!-- Password strength meter -->
        <div class="mb-4">
          <div class="strength-bar-wrap">
            <div class="strength-bar" id="strengthBar"></div>
          </div>
          <small class="strength-label" id="strengthLabel"></small>
        </div>

        <!-- Confirm Password -->
        <div class="mb-4">
          <label for="confirmPassword" class="form-label">Confirm password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input
              type="password"
              class="form-control"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Repeat your password"
              required
            />
            <button class="btn btn-outline-secondary toggle-pw" type="button" data-target="confirmPassword" tabindex="-1">
              <i class="bi bi-eye"></i>
            </button>
            <div class="invalid-feedback">Passwords do not match.</div>
          </div>
        </div>

        <!-- Terms -->
        <div class="mb-4 form-check terms-check">
          <input type="checkbox" class="form-check-input" id="terms" name="terms" required />
          <label class="form-check-label" for="terms">
            I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
          </label>
          <div class="invalid-feedback">You must accept the terms to continue.</div>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary w-100 btn-submit" id="submitBtn">
          <span class="btn-label">Create account</span>
          <span class="btn-icon"><i class="bi bi-arrow-right"></i></span>
        </button>

        <div class="divider my-4"><span>or sign up with</span></div>

        <!-- OAuth buttons -->
        <div class="d-flex gap-3">
          <button type="button" class="btn btn-oauth flex-fill">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
          <button type="button" class="btn btn-oauth flex-fill">
            <i class="bi bi-github"></i>
            GitHub
          </button>
        </div>

      </form>
    </div>
  </main>

</div>

<%- include('footer') %>
